# Argus environment variables
# Copy to .env.local and fill in. Never commit real values.
# All keys here are SERVER-SIDE only and must never be exposed to the browser.

# --- Ethereum (Alchemy primary, Etherscan fallback) ---
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here   # optional fallback

# --- Solana (Helius) ---
HELIUS_API_KEY=your_helius_api_key_here

# --- Bitcoin ---
# Blockstream / Mempool.space need no key for the MVP. Override base URLs if self-hosting.
# BITCOIN_API_BASE_URL=https://blockstream.info/api

# --- Prices (CoinGecko) ---
COINGECKO_API_KEY=                              # optional on the free tier

# --- Cache + rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# --- Observability (optional, post-MVP) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
